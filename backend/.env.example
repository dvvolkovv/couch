# Application
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# Database
DATABASE_URL=postgresql://soulmate:soulmate_pass@localhost:5432/soulmate?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# AI - DeepSeek (primary LLM, OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# YooKassa (payments)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret

# S3-compatible storage (Yandex Object Storage)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=soulmate-uploads
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# SMS provider
SMS_PROVIDER=stub
SMS_API_KEY=your-sms-api-key

# Email provider
EMAIL_PROVIDER=stub
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@soulmate.ru

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
